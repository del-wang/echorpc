{
	"name": "echorpc",
	"version": "1.0.0",
	"description": "Bidirectional JSON-RPC 2.0 over WebSocket — TypeScript & Python.",
	"author": "Del Wang <hello@xbox.work> (https://del.wang)",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/del-wang/echorpc",
		"directory": "typescript"
	},
	"homepage": "https://github.com/del-wang/echorpc",
	"bugs": "https://github.com/del-wang/echorpc/issues",
	"keywords": [
		"rpc",
		"json-rpc",
		"websocket",
		"bidirectional",
		"pubsub",
		"python",
		"nodejs",
		"browser"
	],
	"files": [
		"dist"
	],
	"type": "module",
	"types": "./dist/index.d.ts",
	"module": "./dist/index.js",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./*": {
			"types": "./dist/*.d.ts",
			"import": "./dist/*.js"
		}
	},
	"scripts": {
		"build": "tsdown",
		"test": "vitest run",
		"lint": "biome check --write --no-errors-on-unmatched --diagnostic-level=error ."
	},
	"peerDependencies": {
		"ws": ">=8.0.0"
	},
	"peerDependenciesMeta": {
		"ws": {
			"optional": true
		}
	},
	"devDependencies": {
		"@types/ws": "^8.5.13",
		"tsdown": "^0.21.7",
		"typescript": "^5.6.0",
		"vite": "^6.0.0",
		"vitest": "^3.0.0",
		"ws": "^8.18.0"
	}
}
