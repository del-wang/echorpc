{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"declaration": true,
		"outDir": "dist",
		"rootDir": "src",
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"lib": ["ES2022", "DOM"]
	},
	"include": ["src", "tests", "vitest.config.ts"],
	"exclude": ["node_modules", "dist", "examples"]
}
